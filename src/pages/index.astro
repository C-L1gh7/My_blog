---
import BaseLayout from '../layouts/BaseLayout.astro';
import Navbar from '../components/Navbar';
import ProfileCard from '../components/ProfileCard';
import PostList from '../components/PostList';
import { IconGithub, IconMail } from '../components/Icons';
import { getCollection, render } from 'astro:content';

const allPosts = await getCollection('posts');
const sortedPosts = allPosts.sort((a, b) => new Date(b.data.date).valueOf() - new Date(a.data.date).valueOf());
const latestPosts = sortedPosts
    .slice(0, 2)
    .map(post => ({...post.data, id: post.id, slug: post.slug}));

const allProjects = await getCollection('projects');
const sortedProjects = allProjects.sort((a, b) => new Date(b.data.date).valueOf() - new Date(a.data.date).valueOf());
const latestProjects = await Promise.all(
    sortedProjects
        .slice(0, 2)
        .map(async (p) => ({ entry: p, rendered: await render(p) }))
);

const allNotes = await getCollection('notes');
const sortedNotes = allNotes.sort((a, b) => new Date(b.data.date).valueOf() - new Date(a.data.date).valueOf());

const timeline = [
    ...sortedPosts.slice(0, 3).map(p => ({ type: 'post' as const, title: p.data.title, date: p.data.date, slug: p.slug })),
    ...sortedProjects.slice(0, 2).map(p => ({ type: 'project' as const, title: p.data.title, date: p.data.date })),
    ...sortedNotes.slice(0, 2).map(n => ({ type: 'note' as const, title: n.data.title, date: n.data.date })),
].sort((a, b) => new Date(b.date).valueOf() - new Date(a.date).valueOf()).slice(0, 6);

const title = "C_L1gh7 - 个人博客";
const baseUrl = import.meta.env.BASE_URL;
---

<BaseLayout title={title}>
    <Navbar client:load />

    <div class="content-container pt-28">
        <div class="grid grid-cols-1 lg:grid-cols-12 gap-12 items-start">

            <aside class="lg:col-span-4 hidden lg:block h-full">
                <ProfileCard timeline={timeline} client:load />
            </aside>

            <div class="lg:hidden col-span-1 mb-8">
                <div class="flex items-center gap-4 mb-4">
                    <div class="w-16 h-16 bg-black rounded-full overflow-hidden">
                        <img src="https://pub-f15d478863f747a68de4bbf63631ccfe.r2.dev/PicGo/%E5%A4%B4%E5%83%8F.jpg" class="w-full h-full object-cover" alt="Avatar"/>
                    </div>
                    <div>
                        <h2 class="font-black uppercase text-lg">C_L1gh7</h2>
                        <p class="text-xs text-gray-600">光电信息科学与工程 / Retro Fan</p>
                    </div>
                </div>
                <p class="text-sm text-gray-600 leading-relaxed mb-4">平庸的物理生错奇数个负号，优秀的物理生错偶数个负号。</p>
                <div class="flex gap-4">
                    <a href="https://github.com/C-L1gh7" target="_blank" rel="noopener noreferrer" class="p-2 border border-black hover:bg-black hover:text-white transition-colors rounded-full inline-flex items-center justify-center">
                        <IconGithub className="w-4 h-4"/>
                    </a>
                    <a href="mailto:HuanyuYuan@mail.ecust.edu.cn" class="p-2 border border-black hover:bg-black hover:text-white transition-colors rounded-full inline-flex items-center justify-center">
                        <IconMail className="w-4 h-4"/>
                    </a>
                </div>
                <div class="mt-4 font-mono text-[10px] text-gray-500 break-all select-all">
                    HuanyuYuan@mail.ecust.edu.cn
                </div>
            </div>

            <main class="lg:col-span-8 space-y-8">

                {/* Latest Projects */}
                {latestProjects.length > 0 && (
                    <div>
                        <div class="flex items-end justify-between border-b-2 border-black pb-4 mb-8">
                            <h1 class="text-2xl font-black uppercase tracking-tight">Latest Projects</h1>
                            <a href={`${baseUrl}/projects`} class="font-mono text-xs font-bold hover:text-red-600 transition-colors">
                                ALL PROJECTS →
                            </a>
                        </div>
                        <div class="flex flex-col gap-6">
                            {latestProjects.map(({ entry: p, rendered: { Content } }) => (
                                <article class="bg-white border border-black/10 flex flex-col sm:flex-row overflow-hidden">
                                    {p.data.image && (
                                        <div class="sm:w-52 h-48 sm:h-auto bg-gray-200 shrink-0 border-b sm:border-b-0 sm:border-r border-black/10 overflow-hidden">
                                            <img src={p.data.image} alt={p.data.title} class="w-full h-full object-cover" />
                                        </div>
                                    )}
                                    <div class={`flex flex-col flex-grow ${p.data.image ? 'px-4 sm:px-5 pb-5 pt-4 sm:pt-5' : 'p-5'}`}>
                                        <div class="flex items-center gap-3 font-mono text-[10px] font-bold text-gray-400 mb-2">
                                            <span class="text-black">{p.data.date}</span>
                                            <span class="w-1 h-1 bg-gray-300 rounded-full" />
                                            <span class="uppercase tracking-wider text-red-600">PROJECT</span>
                                        </div>
                                        <h3 class="text-xl font-bold mb-3 leading-tight">{p.data.title}</h3>
                                        <div class="prose prose-sm prose-p:my-1 prose-li:my-0.5 prose-ul:my-1 max-w-none text-gray-600 mb-4">
                                            <Content />
                                        </div>
                                        <div class="flex flex-wrap items-center gap-2 mb-4">
                                            <span class="font-mono text-[10px] font-bold text-gray-400 uppercase tracking-wider shrink-0">TECH:</span>
                                            {p.data.technologies.map((tech) => (
                                                <span class="font-mono text-[10px] font-bold text-gray-500 hover:text-black transition-colors">
                                                    #{tech}
                                                </span>
                                            ))}
                                        </div>
                                        {(p.data.codeUrl || p.data.docsUrl || p.data.videoUrl) && (
                                            <div class="mt-auto flex items-center gap-2 pt-3 border-t border-black/10">
                                                {p.data.codeUrl && (
                                                    <a href={p.data.codeUrl} target="_blank" rel="noopener noreferrer"
                                                        class="flex items-center gap-1.5 px-3 py-1 border border-black text-[10px] font-mono font-bold uppercase hover:bg-black hover:text-white transition-colors">
                                                        <svg class="w-3 h-3" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polyline points="16 18 22 12 16 6"/><polyline points="8 6 2 12 8 18"/></svg> Code
                                                    </a>
                                                )}
                                                {p.data.docsUrl && (
                                                    <a href={p.data.docsUrl} target="_blank" rel="noopener noreferrer"
                                                        class="flex items-center gap-1.5 px-3 py-1 border border-black text-[10px] font-mono font-bold uppercase hover:bg-black hover:text-white transition-colors">
                                                        <svg class="w-3 h-3" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M14.5 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V7.5L14.5 2z"/><polyline points="14 2 14 8 20 8"/></svg> Docs
                                                    </a>
                                                )}
                                                {p.data.videoUrl && (
                                                    <a href={p.data.videoUrl} target="_blank" rel="noopener noreferrer"
                                                        class="flex items-center gap-1.5 px-3 py-1 border border-black text-[10px] font-mono font-bold uppercase hover:bg-black hover:text-white transition-colors">
                                                        <svg class="w-3 h-3" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polygon points="5 3 19 12 5 21 5 3"/></svg> Video
                                                    </a>
                                                )}
                                            </div>
                                        )}
                                    </div>
                                </article>
                            ))}
                        </div>
                    </div>
                )}

                {/* Latest Posts */}
                <div class="pt-8">
                    <div class="flex items-end justify-between border-b-2 border-black pb-4 mb-8">
                        <h2 class="text-2xl font-black uppercase tracking-tight">Latest Posts</h2>
                        <a href={`${baseUrl}/posts`} class="font-mono text-xs font-bold hover:text-red-600 transition-colors">
                            ALL POSTS →
                        </a>
                    </div>
                    {latestPosts.length > 0 ? (
                        <PostList client:load posts={latestPosts} />
                    ) : (
                        <p class="text-gray-500 font-mono text-sm">No posts found.</p>
                    )}
                </div>

            </main>
        </div>
    </div>
</BaseLayout>
