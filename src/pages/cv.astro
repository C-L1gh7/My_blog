---
import BaseLayout from '../layouts/BaseLayout.astro';
import Navbar from '../components/Navbar';

const title = "CV";
const baseUrl = import.meta.env.BASE_URL;

// 方案 1（推荐）：使用 CDN
// 将 CV PDF 上传到 Cloudflare R2，然后取消下面这行的注释并替换 URL
// const cvPdfUrl = "https://pub-f15d478863f747a68de4bbf631ccfe.r2.dev/PicGo/cv.pdf";

// 方案 2：本地托管
// 将 cv.pdf 放到 public/ 目录下，然后取消下面这行的注释
const cvPdfUrl = `${baseUrl}/cv.pdf`;
---

<BaseLayout title={title}>
    <Navbar client:load />

    <div class="content-container pt-28 pb-20">
      <div class="flex items-end justify-between border-b-2 border-black pb-4 mb-8">
            <h1 class="text-4xl font-black uppercase tracking-tight">Curriculum Vitae</h1>
            <a href={cvPdfUrl} target="_blank" class="px-4 py-2 bg-black text-white text-xs font-mono font-bold uppercase hover:bg-red-600 transition-colors">
                ↓ Download PDF
            </a>
      </div>

      <div class="border-2 border-black shadow-[6px_6px_0px_#000]">
        <iframe
          src={cvPdfUrl}
          width="100%"
          height="800px"
          style="border: none; display: block;"
        ></iframe>
      </div>

      <p class="text-center font-mono text-xs text-gray-400 mt-4">
        如果 PDF 无法显示，请点击上方按钮下载查看。
      </p>
    </div>
</BaseLayout>
