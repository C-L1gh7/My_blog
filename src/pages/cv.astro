---
import BaseLayout from '../layouts/BaseLayout.astro';
import Navbar from '../components/Navbar';

const title = "CV";
const baseUrl = import.meta.env.BASE_URL;

// 方案 1（推荐）：使用 CDN
// 将 CV PDF 上传到 Cloudflare R2，然后取消下面这行的注释并替换 URL
// const cvPdfUrl = "https://pub-f15d478863f747a68de4bbf631ccfe.r2.dev/PicGo/cv.pdf";

// 方案 2：本地托管
// 将 cv.pdf 放到 public/ 目录下，然后取消下面这行的注释
const cvPdfUrl = `${baseUrl}cv.pdf`;
---

<BaseLayout title={title}>
    <Navbar client:load />

    <div class="content-container pt-28 pb-20">
      <div class="flex items-end justify-between border-b-2 border-black pb-4 mb-8">
            <h1 class="text-2xl sm:text-3xl md:text-4xl font-black uppercase tracking-tight">Curriculum Vitae</h1>
            <a href={cvPdfUrl} target="_blank" class="px-3 sm:px-4 py-2 bg-black text-white text-xs font-mono font-bold uppercase hover:bg-red-600 active:scale-95 transition-all shrink-0 ml-3">
                ↓ Download
            </a>
      </div>

      <!-- Desktop: iframe viewer -->
      <div class="hidden sm:block border-2 border-black shadow-[6px_6px_0px_#000]">
        <iframe
          src={cvPdfUrl}
          width="100%"
          height="800px"
          style="border: none; display: block;"
        ></iframe>
      </div>

      <!-- Mobile: download prompt -->
      <div class="sm:hidden text-center py-16 bg-white border border-black/10">
        <div class="font-mono text-xs text-gray-400 uppercase tracking-widest mb-2">PDF VIEWER</div>
        <p class="text-sm text-gray-500 mb-6 px-4">移动端建议直接下载 PDF 查看，获得更好的阅读体验。</p>
        <a href={cvPdfUrl} target="_blank" class="inline-flex items-center gap-2 px-6 py-3 bg-black text-white text-xs font-mono font-bold uppercase hover:bg-red-600 active:scale-95 transition-all">
            ↓ DOWNLOAD PDF
        </a>
      </div>

      <p class="text-center font-mono text-xs text-gray-400 mt-4">
        如果 PDF 无法显示，请点击上方按钮下载查看。
      </p>
    </div>
</BaseLayout>
