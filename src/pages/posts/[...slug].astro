---
import { getCollection } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
import Navbar from '../../components/Navbar';

export async function getStaticPaths() {
  const posts = await getCollection('posts');
  return posts.map(post => ({
    params: { slug: post.slug },
    props: { post },
  }));
}

const { post } = Astro.props;
const { Content } = await post.render();
---

<BaseLayout title={post.data.title}>
    <Navbar client:load />

    <div class="content-container pt-28 pb-20">
      <a href={`${import.meta.env.BASE_URL}posts/`} id="go-back" class="inline-block mb-8 font-mono text-xs font-bold hover:text-red-600 transition-colors">
        &larr; GO BACK
      </a>

      <script>
        const backLink = document.getElementById('go-back');
        if (backLink) {
            backLink.addEventListener('click', (e) => {
                // 如果有来源页面，且来源页面属于本站，则执行后退
                if (document.referrer && document.referrer.includes(window.location.host)) {
                    e.preventDefault();
                    window.history.back();
                }
            });
        }
      </script>

      <div class="bg-white md:border-2 md:border-black p-4 sm:p-6 md:p-12 md:shadow-[8px_8px_0px_#ccc]">
          <article class="prose prose-sm sm:prose-base md:prose-lg max-w-none mx-auto">
            <header class="mb-8 md:mb-12 border-b-2 border-black pb-6 md:pb-8">
                <div class="flex items-center gap-3 font-mono text-xs font-bold text-gray-500 mb-4">
                    <span class="text-black">{post.data.date}</span>
                    <span class="w-1 h-1 bg-gray-300 rounded-full"></span>
                    <span class="uppercase tracking-wider text-red-600">{post.data.tag || 'GENERAL'}</span>
                </div>
                <h1 class="text-2xl sm:text-3xl md:text-5xl font-black uppercase tracking-tight mb-6 leading-tight">{post.data.title}</h1>
                {post.data.image && (
                    <div class="w-full bg-gray-100 mt-6 md:mt-8 border-2 border-black overflow-hidden relative flex justify-center items-center">
                        <img
                            src={post.data.image}
                            alt={post.data.title}
                            class="max-w-full h-auto max-h-[600px] object-contain"
                        />
                    </div>
                )}
            </header>

            <div class="font-serif leading-relaxed text-base md:text-lg text-gray-800">
                <Content />
            </div>
          </article>
      </div>
    </div>
</BaseLayout>

<style is:global>
  /* ── Overlay backdrop ── */
  .img-zoom-overlay {
    position: fixed;
    inset: 0;
    width: 100dvw;
    height: 100dvh;
    z-index: 9999;
    background: rgba(255, 255, 255, 0.55);
    backdrop-filter: blur(18px);
    -webkit-backdrop-filter: blur(18px);
    opacity: 0;
    visibility: hidden;
    transition: opacity 0.25s ease, visibility 0.25s ease;
  }

  .img-zoom-overlay.active {
    opacity: 1;
    visibility: visible;
  }

  /* ── Stage (contains the image) ── */
  .img-zoom-stage {
    position: absolute;
    inset: 0;
  }

  .img-zoom-stage img {
    position: absolute;
    top: 0;
    left: 0;
    transform-origin: 0 0;
    will-change: transform;
    border-radius: 4px;
    box-shadow: 0 20px 60px -20px rgba(0, 0, 0, 0.3), 0 0 0 1px rgba(0, 0, 0, 0.05);
    user-select: none;
    -webkit-user-drag: none;
    pointer-events: auto;
  }

  .img-zoom-stage img.transitioning {
    transition: transform 0.3s cubic-bezier(0.25, 0.46, 0.45, 0.94);
  }

  /* ── Zoom indicator badge ── */
  .img-zoom-badge {
    position: fixed;
    bottom: 28px;
    left: 50%;
    transform: translateX(-50%);
    z-index: 10002;
    background: rgba(0, 0, 0, 0.06);
    backdrop-filter: blur(10px);
    -webkit-backdrop-filter: blur(10px);
    border-radius: 20px;
    padding: 6px 16px;
    font-family: 'JetBrains Mono', monospace;
    font-size: 12px;
    color: #444;
    opacity: 0;
    transition: opacity 0.2s;
    pointer-events: none;
    letter-spacing: 0.5px;
  }

  .img-zoom-badge.visible {
    opacity: 1;
  }
</style>

<script>
  (function () {
    /* ================================================================
       Image Zoom Lightbox — scroll to zoom, drag to pan, dblclick toggle
       ================================================================ */
    const MARGIN = 0.85;
    const ZOOM_STEP = 0.3;
    const MIN_ZOOM = 0.5;
    const MAX_ZOOM = 10;
    const DBLCLICK_ZOOM = 2.5;

    /* --- DOM scaffolding --- */
    const overlay = document.createElement('div');
    overlay.className = 'img-zoom-overlay';
    overlay.innerHTML = `
      <div class="img-zoom-stage"></div>
      <div class="img-zoom-badge"></div>
    `;
    document.body.appendChild(overlay);

    const stage     = overlay.querySelector('.img-zoom-stage');
    const img       = stage.appendChild(document.createElement('img'));
    const badge     = overlay.querySelector('.img-zoom-badge');

    /* --- State --- */
    let zoom      = MIN_ZOOM;       // user-zoom multiplier (1 = fit-screen)
    let panX      = 0;             // px offset from centered position
    let panY      = 0;
    let baseScale = 1;             // scale that makes image fit 90vw/90vh
    let nw = 0, nh = 0;            // natural image dimensions
    let badgeTimer = 0;

    /* ================================================================
       Helpers
       ================================================================ */
    const clamp = (v, lo, hi) => Math.min(Math.max(v, lo), hi);

    /** Reliable viewport dimensions — visualViewport accounts for mobile
        address bar, on-screen keyboard etc. */
    function vpW() { return window.visualViewport?.width  ?? window.innerWidth; }
    function vpH() { return window.visualViewport?.height ?? window.innerHeight; }

    /** Total CSS scale = baseScale * zoom */
    function totalScale() { return baseScale * zoom; }

    /** Image top-left in viewport coords at current state */
    function imgLeft() {
      return (vpW()  - nw * totalScale()) / 2 + panX;
    }
    function imgTop() {
      return (vpH() - nh * totalScale()) / 2 + panY;
    }

    /** Recompute baseScale from natural dims & viewport */
    function recalcBase() {
      if (!nw || !nh) return;
      baseScale = Math.min(
        (MARGIN * vpW())  / nw,
        (MARGIN * vpH()) / nh,
        1
      );
    }

    /** Apply current state to the DOM */
    function applyTransform(animate = false) {
      const ts = totalScale();
      const l = imgLeft();
      const t = imgTop();
      img.classList.toggle('transitioning', animate);
      img.style.transform = `translate(${l}px, ${t}px) scale(${ts})`;
    }

    /** Constrain pan so image edges never leave viewport edges */
    function clampPan() {
      if (zoom <= MIN_ZOOM) { panX = 0; panY = 0; return; }
      const ts  = totalScale();
      const rw  = nw * ts;
      const rh  = nh * ts;
      const maxX = Math.max(0, (rw - vpW())  / 2);
      const maxY = Math.max(0, (rh - vpH()) / 2);
      panX = clamp(panX, -maxX, maxX);
      panY = clamp(panY, -maxY, maxY);
    }

    /** Whether the image currently overflows the viewport (pannable) */
    function isOverflowing() {
      const ts = totalScale();
      return nw * ts > vpW() || nh * ts > vpH();
    }

    /** Set cursor based on whether image overflows viewport */
    function updateCursor() {
      if (isOverflowing()) {
        img.style.cursor = 'grab';
        overlay.style.cursor = 'default';
      } else {
        img.style.cursor = 'zoom-in';
        overlay.style.cursor = 'default';
      }
    }

    /** Flash the zoom-percentage badge for 1.2 s */
    function showBadge() {
      const pct = Math.round(zoom * 100);
      badge.textContent = pct + '%';
      badge.classList.add('visible');
      clearTimeout(badgeTimer);
      badgeTimer = setTimeout(() => badge.classList.remove('visible'), 1200);
    }

    /** Reset to fit-screen */
    function resetView(animate = false) {
      zoom = MIN_ZOOM;
      panX = 0;
      panY = 0;
      clampPan();
      applyTransform(animate);
      updateCursor();
      showBadge();
    }

    /* ================================================================
       Open / Close
       ================================================================ */
    function open(src, alt) {
      img.src = src;
      img.alt = alt || '';

      function onLoad() {
        nw = img.naturalWidth;
        nh = img.naturalHeight;
        if (!nw || !nh) return;
        recalcBase();
        resetView(false);
        overlay.classList.add('active');
        document.body.style.overflow = 'hidden';
      }

      if (img.complete && img.naturalWidth) {
        onLoad();
      } else {
        img.addEventListener('load', onLoad, { once: true });
      }
    }

    function close() {
      overlay.classList.remove('active');
      document.body.style.overflow = '';
      badge.classList.remove('visible');
      clearTimeout(badgeTimer);
      setTimeout(() => { img.src = ''; }, 300);
    }

    /* ================================================================
       Wheel → zoom toward cursor
       ================================================================ */
    overlay.addEventListener('wheel', (e) => {
      if (!overlay.classList.contains('active')) return;
      e.preventDefault();

      const oldZoom = zoom;
      const delta = -Math.sign(e.deltaY) * ZOOM_STEP;
      zoom = clamp(oldZoom + delta * (oldZoom * 0.5 + 0.5), MIN_ZOOM, MAX_ZOOM);
      if (zoom === oldZoom) return;

      // Keep the point under the cursor pinned
      const cx = e.clientX, cy = e.clientY;
      const oldLeft = imgLeft(), oldTop = imgTop();
      panX = cx - (cx - oldLeft) * (zoom / oldZoom) - (vpW()  - nw * totalScale()) / 2;
      panY = cy - (cy - oldTop)  * (zoom / oldZoom) - (vpH() - nh * totalScale()) / 2;

      clampPan();
      applyTransform(false);
      updateCursor();
    }, { passive: false });

    /* ================================================================
       Mouse drag → pan
       ================================================================ */
    let dragging = false;
    let justDragged = false;
    let dragSX = 0, dragSY = 0, panSX = 0, panSY = 0;

    img.addEventListener('mousedown', (e) => {
      if (!isOverflowing()) return;
      e.preventDefault();
      dragging = true;
      justDragged = false;
      dragSX = e.clientX; dragSY = e.clientY;
      panSX  = panX;       panSY  = panY;
      img.style.cursor = 'grabbing';
    });

    document.addEventListener('mousemove', (e) => {
      if (!dragging) return;
      if (Math.abs(e.clientX - dragSX) > 3 || Math.abs(e.clientY - dragSY) > 3) {
        justDragged = true;
      }
      panX = panSX + (e.clientX - dragSX);
      panY = panSY + (e.clientY - dragSY);
      clampPan();
      applyTransform(false);
    });

    document.addEventListener('mouseup', () => {
      if (!dragging) return;
      dragging = false;
      img.style.cursor = isOverflowing() ? 'grab' : 'zoom-in';
    });

    /* ================================================================
       Double-click → toggle between fit and 2.5×
       ================================================================ */
    img.addEventListener('dblclick', (e) => {
      if (!overlay.classList.contains('active')) return;
      e.preventDefault();

      if (isOverflowing()) {
        resetView(true);
        return;
      }

      const oldZoom = zoom;
      zoom = DBLCLICK_ZOOM;
      const cx = e.clientX, cy = e.clientY;
      const oldLeft = imgLeft(), oldTop = imgTop();
      panX = cx - (cx - oldLeft) * (zoom / oldZoom) - (vpW()  - nw * totalScale()) / 2;
      panY = cy - (cy - oldTop)  * (zoom / oldZoom) - (vpH() - nh * totalScale()) / 2;

      clampPan();
      applyTransform(true);
      updateCursor();
      showBadge();
    });

    /* ================================================================
       Touch: single-finger pan + two-finger pinch
       ================================================================ */
    let touches0 = null;        // Touch[] for the current gesture
    let pinchDist0 = 0;        // starting finger distance
    let pinchZoom0 = 1;        // zoom at pinch start
    let pinchCX = 0, pinchCY = 0;  // midpoint of pinch at start
    let panTX = 0, panTY = 0;  // pan at gesture start

    stage.addEventListener('touchstart', (e) => {
      if (!overlay.classList.contains('active')) return;
      if (e.touches.length === 1) {
        // single finger → pan (only when zoomed in)
        if (!isOverflowing()) return;
        touches0 = [e.touches[0]];
        panTX = panX; panTY = panY;
        e.preventDefault();
      } else if (e.touches.length === 2) {
        // pinch
        const [t0, t1] = [e.touches[0], e.touches[1]];
        touches0 = [t0, t1];
        pinchDist0 = Math.hypot(t1.clientX - t0.clientX, t1.clientY - t0.clientY);
        pinchZoom0 = zoom;
        pinchCX = (t0.clientX + t1.clientX) / 2;
        pinchCY = (t0.clientY + t1.clientY) / 2;
        panTX = panX; panTY = panY;
        e.preventDefault();
      }
    }, { passive: false });

    stage.addEventListener('touchmove', (e) => {
      if (!touches0) return;
      if (touches0.length === 1 && e.touches.length === 1) {
        // pan
        const dx = e.touches[0].clientX - touches0[0].clientX;
        const dy = e.touches[0].clientY - touches0[0].clientY;
        if (Math.abs(dx) > 3 || Math.abs(dy) > 3) justDragged = true;
        panX = panTX + dx;
        panY = panTY + dy;
        clampPan();
        applyTransform(false);
        e.preventDefault();
      } else if (touches0.length === 2 && e.touches.length === 2) {
        const [t0, t1] = [e.touches[0], e.touches[1]];
        const dist = Math.hypot(t1.clientX - t0.clientX, t1.clientY - t0.clientY);
        const cx   = (t0.clientX + t1.clientX) / 2;
        const cy   = (t0.clientY + t1.clientY) / 2;

        const oldZoom = zoom;
        zoom = clamp(pinchZoom0 * (dist / pinchDist0), MIN_ZOOM, MAX_ZOOM);
        if (Math.abs(zoom - oldZoom) > 0.005) justDragged = true;

        // zoom toward moving midpoint
        const oldLeft = (vpW()  - nw * baseScale * oldZoom)  / 2 + panTX;
        const oldTop  = (vpH() - nh * baseScale * oldZoom) / 2 + panTY;
        // position at start of gesture, adjusted for zoom change & midpoint drift
        const newLeft = cx - (cx - oldLeft) * (zoom / oldZoom)
                        - (cx - pinchCX) * (zoom / pinchZoom0);
        const newTop  = cy - (cy - oldTop)  * (zoom / oldZoom)
                        - (cy - pinchCY) * (zoom / pinchZoom0);

        panX = newLeft - (vpW()  - nw * totalScale()) / 2;
        panY = newTop  - (vpH() - nh * totalScale()) / 2;

        clampPan();
        applyTransform(false);
        updateCursor();
        showBadge();
        e.preventDefault();
      }
    }, { passive: false });

    stage.addEventListener('touchend', () => {
      touches0 = null;
      // Reset justDragged after a tick so it's still set when the
      // synthetic click fires, but cleared afterwards
      if (justDragged) setTimeout(() => { justDragged = false; }, 50);
    });

    /* ================================================================
       Close triggers
       ================================================================ */
    overlay.addEventListener('click', (e) => {
      if (justDragged) { justDragged = false; return; }
      if (e.target === overlay || e.target === stage) close();
    });

    document.addEventListener('keydown', (e) => {
      if (e.key === 'Escape' && overlay.classList.contains('active')) close();
    });

    /* ================================================================
       Viewport resize (including mobile address-bar shows/hides)
       ================================================================ */
    function onViewportChange() {
      if (!overlay.classList.contains('active')) return;
      recalcBase();
      clampPan();
      applyTransform(false);
    }
    window.addEventListener('resize', onViewportChange);
    if (window.visualViewport) {
      window.visualViewport.addEventListener('resize', onViewportChange);
      window.visualViewport.addEventListener('scroll', onViewportChange);
    }

    /* ================================================================
       Attach click-to-open on page images
       ================================================================ */
    function isInsideLink(el) {
      let p = el.parentElement;
      while (p && p !== document.body) {
        if (p.tagName === 'A') return true;
        p = p.parentElement;
      }
      return false;
    }

    function isSmallDecorative(el) {
      return (el.naturalWidth > 0 && el.naturalWidth < 200) ||
             (el.naturalHeight > 0 && el.naturalHeight < 200);
    }

    function attach(el) {
      if (el.dataset.zoomAttached) return;
      el.dataset.zoomAttached = '1';
      if (isInsideLink(el)) return;

      const tryAttach = () => {
        if (isSmallDecorative(el)) return;
        el.style.cursor = 'zoom-in';
        el.addEventListener('click', (e) => {
          e.preventDefault();
          e.stopPropagation();
          open(el.currentSrc || el.src, el.alt);
        });
      };

      if (el.complete) { tryAttach(); }
      else { el.addEventListener('load', tryAttach, { once: true }); }
    }

    document.querySelectorAll('.prose img').forEach(attach);
    const headerImg = document.querySelector('header img');
    if (headerImg) attach(headerImg);

    const article = document.querySelector('article');
    if (article) {
      new MutationObserver((mutations) => {
        for (const m of mutations) {
          for (const node of m.addedNodes) {
            if (node.nodeType === 1) {
              if (node.tagName === 'IMG') attach(node);
              node.querySelectorAll?.('img')?.forEach(attach);
            }
          }
        }
      }).observe(article, { childList: true, subtree: true });
    }
  })();
</script>
