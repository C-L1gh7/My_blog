---
import BaseLayout from '../layouts/BaseLayout.astro';
import Navbar from '../components/Navbar';
import { getCollection, render } from 'astro:content';

const projects = await getCollection('projects');
const allProjects = await Promise.all(
    projects
        .sort((a, b) => new Date(b.data.date).valueOf() - new Date(a.data.date).valueOf())
        .map(async (p) => {
            const { Content } = await render(p);
            // render to static HTML string via a temporary approach
            return {
                title: p.data.title,
                description: p.data.description ?? '',
                date: p.data.date,
                image: p.data.image,
                technologies: p.data.technologies,
                codeUrl: p.data.codeUrl,
                docsUrl: p.data.docsUrl,
                videoUrl: p.data.videoUrl,
                slug: p.id,
            };
        })
);

const title = "Projects";
---

<BaseLayout title={title}>
    <Navbar client:load />

    <div class="content-container pt-28 pb-20">
        <div class="flex items-end justify-between border-b-2 border-black pb-4 mb-12">
            <h1 class="text-4xl font-black uppercase tracking-tight">Projects</h1>
            <span class="font-mono text-xs font-bold">SHOWCASE</span>
        </div>

        <div class="flex flex-col gap-6">
            {allProjects.map(async (project) => {
                const entry = projects.find(p => p.id === project.slug)!;
                const { Content } = await render(entry);
                return (
                    <article class="bg-white border border-black/10 flex flex-col sm:flex-row overflow-hidden">
                        {project.image && (
                            <div class="sm:w-52 h-48 sm:h-auto bg-gray-200 shrink-0 border-b sm:border-b-0 sm:border-r border-black/10 overflow-hidden">
                                <img src={project.image} alt={project.title} class="w-full h-full object-cover" />
                            </div>
                        )}
                        <div class={`flex flex-col flex-grow ${project.image ? 'px-4 sm:px-5 pb-5 pt-4 sm:pt-5' : 'p-5'}`}>
                            <div class="flex items-center gap-3 font-mono text-[10px] font-bold text-gray-400 mb-2">
                                <span class="text-black">{project.date}</span>
                                <span class="w-1 h-1 bg-gray-300 rounded-full" />
                                <span class="uppercase tracking-wider text-red-600">PROJECT</span>
                            </div>
                            <h3 class="text-xl font-bold mb-3 leading-tight">{project.title}</h3>
                            <div class="prose prose-sm prose-p:my-1 prose-li:my-0.5 prose-ul:my-1 max-w-none text-gray-600 mb-4">
                                <Content />
                            </div>
                            <div class="flex flex-wrap items-center gap-2 mb-4">
                                <span class="font-mono text-[10px] font-bold text-gray-400 uppercase tracking-wider shrink-0">TECH:</span>
                                {project.technologies.map((tech) => (
                                    <span class="font-mono text-[10px] font-bold text-gray-500 hover:text-black transition-colors">
                                        #{tech}
                                    </span>
                                ))}
                            </div>
                            {(project.codeUrl || project.docsUrl || project.videoUrl) && (
                                <div class="mt-auto flex items-center gap-2 pt-3 border-t border-black/10">
                                    {project.codeUrl && (
                                        <a href={project.codeUrl} target="_blank" rel="noopener noreferrer"
                                            class="flex items-center gap-1.5 px-3 py-1 border border-black text-[10px] font-mono font-bold uppercase hover:bg-black hover:text-white transition-colors">
                                            <svg class="w-3 h-3" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polyline points="16 18 22 12 16 6"/><polyline points="8 6 2 12 8 18"/></svg> Code
                                        </a>
                                    )}
                                    {project.docsUrl && (
                                        <a href={project.docsUrl} target="_blank" rel="noopener noreferrer"
                                            class="flex items-center gap-1.5 px-3 py-1 border border-black text-[10px] font-mono font-bold uppercase hover:bg-black hover:text-white transition-colors">
                                            <svg class="w-3 h-3" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M14.5 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V7.5L14.5 2z"/><polyline points="14 2 14 8 20 8"/></svg> Docs
                                        </a>
                                    )}
                                    {project.videoUrl && (
                                        <a href={project.videoUrl} target="_blank" rel="noopener noreferrer"
                                            class="flex items-center gap-1.5 px-3 py-1 border border-black text-[10px] font-mono font-bold uppercase hover:bg-black hover:text-white transition-colors">
                                            <svg class="w-3 h-3" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polygon points="5 3 19 12 5 21 5 3"/></svg> Video
                                        </a>
                                    )}
                                </div>
                            )}
                        </div>
                    </article>
                );
            })}
        </div>
    </div>
</BaseLayout>
