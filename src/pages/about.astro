---
import BaseLayout from '../layouts/BaseLayout.astro';
import Navbar from '../components/Navbar';

const title = "About Me";
---

<BaseLayout title={title}>
    <Navbar client:load />

    <div class="content-container pt-28 pb-20">
      <h1 class="text-2xl sm:text-3xl md:text-4xl font-black uppercase tracking-tight mb-6 md:mb-8 border-b-2 border-black pb-4">About Me</h1>

      <div class="prose prose-sm sm:prose-base md:prose-lg max-w-none font-serif leading-relaxed">

        {/* Intro */}
        <section class="mb-8 md:mb-12">
            <h2 class="text-xl sm:text-2xl font-black uppercase tracking-tight mb-4 sm:mb-6">👋 你好! 我是 袁焕予 / C_L1gh7</h2>
            <p class="text-base sm:text-xl">
                <span class="font-bold bg-yellow-200 px-1 border border-black transform -rotate-1 inline-block shadow-[2px_2px_0px_#000]">光电信息科学与工程</span> 本科在读。
            </p>
        </section>

        {/* Blog Content */}
        <section class="mb-8 md:mb-12 bg-white border md:border-2 border-black/10 md:border-black p-5 sm:p-6 md:p-8 md:shadow-[8px_8px_0px_#ccc]">
            <h3 class="font-black font-mono text-base sm:text-lg mb-4 sm:mb-6 flex items-center gap-2 border-b border-black pb-2 w-full">
                <span class="text-xl sm:text-2xl">💡</span> 这里是我的个人博客：
            </h3>
            <ul class="space-y-3 sm:space-y-4 list-none pl-0 font-bold">
                <li class="flex items-center gap-3 sm:gap-4 hover:translate-x-2 transition-transform cursor-default">
                    <span class="w-7 h-7 sm:w-8 sm:h-8 flex items-center justify-center border border-black rounded-full bg-gray-100 text-lg sm:text-xl shrink-0">🧪</span>
                    <span class="text-sm sm:text-base">科研历程和项目介绍</span>
                </li>
                <li class="flex items-center gap-3 sm:gap-4 hover:translate-x-2 transition-transform cursor-default">
                    <span class="w-7 h-7 sm:w-8 sm:h-8 flex items-center justify-center border border-black rounded-full bg-gray-100 text-lg sm:text-xl shrink-0">📖</span>
                    <span class="text-sm sm:text-base">学习笔记以及技术分享</span>
                </li>
                <li class="flex items-center gap-3 sm:gap-4 hover:translate-x-2 transition-transform cursor-default">
                    <span class="w-7 h-7 sm:w-8 sm:h-8 flex items-center justify-center border border-black rounded-full bg-gray-100 text-lg sm:text-xl shrink-0">💭</span>
                    <span class="text-sm sm:text-base">个人随笔和闲聊</span>
                </li>
            </ul>
        </section>

        {/* Tech Stack */}
        <section>
             <h3 class="font-black font-mono text-base sm:text-lg mb-6 sm:mb-8 flex items-center gap-2 border-b border-black pb-2 w-full">
                <span class="text-xl sm:text-2xl">⚙️</span> 我的技术栈：
            </h3>

            <div class="grid grid-cols-2 md:grid-cols-2 gap-3 sm:gap-6 font-mono text-sm">
                <div class="border border-black p-3 sm:p-4 bg-gray-50 hover:bg-white hover:shadow-[4px_4px_0px_#000] transition-all hover:-translate-y-1">
                    <div class="font-black mb-2 sm:mb-3 flex items-center gap-2 uppercase tracking-wide text-xs sm:text-sm"><span class="text-lg sm:text-xl">💻</span> 编程语言</div>
                    <div class="text-gray-600 font-bold text-xs sm:text-sm">Python, C</div>
                </div>

                <div class="border border-black p-3 sm:p-4 bg-gray-50 hover:bg-white hover:shadow-[4px_4px_0px_#000] transition-all hover:-translate-y-1">
                    <div class="font-black mb-2 sm:mb-3 flex items-center gap-2 uppercase tracking-wide text-xs sm:text-sm"><span class="text-lg sm:text-xl">📊</span> 数据处理</div>
                    <div class="text-gray-600 font-bold text-xs sm:text-sm">OpenCV, NumPy, Matplotlib</div>
                </div>

                <div class="border border-black p-3 sm:p-4 bg-gray-50 hover:bg-white hover:shadow-[4px_4px_0px_#000] transition-all hover:-translate-y-1">
                    <div class="font-black mb-2 sm:mb-3 flex items-center gap-2 uppercase tracking-wide text-xs sm:text-sm"><span class="text-lg sm:text-xl">🛠️</span> 仿真 & 建模</div>
                    <div class="text-gray-600 font-bold text-xs sm:text-sm">COMSOL, CAD, Blender</div>
                </div>

                <div class="border border-black p-3 sm:p-4 bg-gray-50 hover:bg-white hover:shadow-[4px_4px_0px_#000] transition-all hover:-translate-y-1">
                    <div class="font-black mb-2 sm:mb-3 flex items-center gap-2 uppercase tracking-wide text-xs sm:text-sm"><span class="text-lg sm:text-xl">🌐</span> 工具与平台</div>
                    <div class="text-gray-600 font-bold text-xs sm:text-sm">Git, LaTeX, GitHub</div>
                </div>
            </div>
        </section>

      </div>
    </div>
</BaseLayout>